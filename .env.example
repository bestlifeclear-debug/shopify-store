# Публичный URL сайта: для production обязательно https://ваш-домен (ссылки оплаты и редиректы)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (обязательно для каталога и заказов)
# На Vercel: Settings → Environment Variables → добавьте те же ключи для Production и Redeploy.
# URL: Project Settings (шестерёнка) → API → Project URL
#   Должен быть вида https://xxxx.supabase.co БЕЗ /rest/v1/ в конце
# ANON: на той же странице вкладка «Legacy anon, service_role API keys» → anon → public
#   Это длинная строка eyJhbGci... НЕ sb_publishable_... (это другой формат ключа)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — только сервер: webhook, админ-таблица, обновление платежа
SUPABASE_SERVICE_ROLE_KEY=

# ЮMoney — сбор через форму быстрого перевода (не ЮKassa)
# Номер кошелька получателя (в личном кабинете)
YOOMONEY_WALLET=
# Секрет HTTP-уведомлений: https://yoomoney.ru/transfer/myservices/http-notification
# URL уведомлений в настройках кошелька: https://<ваш-домен>/api/payment/webhook
YOOMONEY_NOTIFICATION_SECRET=

# Простая защита админки: /admin/orders?secret=... (длинная случайная строка; URL не светите в логах/реферере)
ADMIN_DASHBOARD_SECRET=

# Отмена «брошенных» онлайн-заказов: pending_payment старше N часов → cancelled
# (при каждом чекауте чистка в фоне + по расписанию см. ниже)
STALE_PENDING_PAYMENT_HOURS=24

# Секрет для GET/POST /api/cron/cancel-stale-payments?secret=... или Authorization: Bearer ...
CRON_SECRET=
